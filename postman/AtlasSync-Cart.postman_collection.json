{
  "info": {
    "_postman_id": "c9e7f1b2-cart-collection-2026",
    "name": "AtlasSync Cart",
    "description": "Shopping cart operations: add, remove, view, help, clear. Broadcasts via WebSocket /topic/cart/{sessionId}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8083" },
    { "key": "sessionId", "value": "PASTE_FROM_SESSIONS_COLLECTION" },
    { "key": "userId", "value": "1" }
  ],
  "item": [
    {
      "id": "c1000001-0000-0000-0000-000000000001",
      "name": "1. Add Barilla Spaghetti",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "{{userId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"barcode\": \"8076802085738\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/cart/{{sessionId}}/items",
          "host": ["{{baseUrl}}"],
          "path": ["api", "cart", "{{sessionId}}", "items"]
        }
      }
    },
    {
      "id": "c1000002-0000-0000-0000-000000000002",
